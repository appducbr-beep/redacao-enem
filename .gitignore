# ============================================================
# REDA1000 — .gitignore
# ============================================================

# --- Dependências ---
node_modules/
.pnp
.pnp.js

# --- Next.js ---
.next/
out/
build/
dist/

# --- Variáveis de ambiente ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs e editores ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Testes ---
coverage/
.nyc_output/

# --- Cache ---
.eslintcache
.stylelintcache
.turbo/
.cache/

# --- Uploads e arquivos temporários ---
uploads/
tmp/
temp/
*.tmp

# --- Pacotes ---
*.tgz
*.zip

# --- Vercel ---
.vercel/

# --- Supabase ---
supabase/.temp/

# --- Banco de dados ---
*.db
*.sqlite